---
import Layout from "@/layouts/Layout.astro";
import { Navbar } from "@/components/Navbar";
import { Hero } from "@/components/Hero";
import Footer from "@/components/Footer.astro";
import { useTranslations, getLangFromUrl } from "@/i18n/ui";
import { SITE_NAME, SITE_TAGLINE } from "@/site.config";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={SITE_NAME} description={SITE_TAGLINE} lang={lang}>
  <Navbar
    lang={lang}
    labels={{
      home: t("nav.home"),
      about: t("nav.about"),
      contact: t("nav.contact"),
    }}
    client:load
  />
  <main>
    <Hero
      title={SITE_NAME}
      ctaText="About"
      ctaLink="/about"
      client:load
    >
      Built with
      <a
        href="https://astro.build"
        target="_blank"
        rel="noopener noreferrer"
        class="font-bold hover:text-primary transition-colors"
      >
        Astro
      </a>,
      <a
        href="https://react.dev"
        target="_blank"
        rel="noopener noreferrer"
        class="font-bold hover:text-primary transition-colors"
      >
        React
      </a>, and
      <a
        href="https://ui.shadcn.com"
        target="_blank"
        rel="noopener noreferrer"
        class="font-bold hover:text-primary transition-colors"
      >
        Shadcn UI
      </a>
    </Hero>
  </main>
  <Footer lang={lang} />
</Layout>
