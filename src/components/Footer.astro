---
import { SITE_NAME, SITE_AUTHOR, SITE_AUTHOR_URL } from "@/site.config";
import { useTranslations, type Locale } from "@/i18n/ui";

interface Props {
  lang?: Locale;
}

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);
---

<footer class="bg-background mt-auto print:hidden">
  <!-- Bottom bar -->
  <div class="border-t border-border">
    <div
      class="container mx-auto px-4 py-8 flex flex-col sm:flex-row items-center justify-between gap-4"
    >
      <div class="text-xs text-muted-foreground/60 order-2 sm:order-1">
        {SITE_NAME} crafted with &hearts; by <a
          href={SITE_AUTHOR_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-muted-foreground transition-colors duration-150 ease-out"
        >
          {SITE_AUTHOR}
        </a>
      </div>
      <div class="text-xs text-muted-foreground/60 order-1 sm:order-2">
        {t("footer.allRightsReserved")}
      </div>
    </div>
  </div>
</footer>
